<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Avalon.MainPage"
             Title="The Resistance">

    <ScrollView>
        <VerticalStackLayout Padding="24"
                Spacing="16">

            <Label Text="The Resistance"
                   Style="{StaticResource Headline}"
                   SemanticProperties.HeadingLevel="Level1"/>

            <Frame BackgroundColor="#F3EEFF"
                   BorderColor="#512BD4"
                   Padding="16">
                <VerticalStackLayout Spacing="6">
                    <Label Text="Status da partida"
                            FontAttributes="Bold"/>
                    <Label x:Name="StatusLabel"
                            Text="Adicione jogadores para começar."/>
                    <Label x:Name="ScoreLabel"
                            Text="Missões aprovadas: 0 | Missões falhas: 0"/>
                </VerticalStackLayout>
            </Frame>

            <VerticalStackLayout x:Name="LobbySection"
                    Spacing="12">
                <Label Text="1) Monte a mesa"
                        FontAttributes="Bold"
                        FontSize="18"/>
                <Label x:Name="LobbyInfoLabel"
                       Text="Adicione entre 5 e 10 jogadores."/>

                <Grid ColumnDefinitions="*,Auto"
                        ColumnSpacing="10">
                    <Entry x:Name="PlayerNameEntry"
                           Placeholder="Nome do jogador"
                           ReturnType="Done"
                           Completed="OnAddPlayerClicked"/>
                    <Button Grid.Column="1"
                            Text="Adicionar"
                            Clicked="OnAddPlayerClicked"/>
                </Grid>

                <HorizontalStackLayout Spacing="10">
                    <Button Text="Resetar lista"
                            Clicked="OnClearPlayersClicked"/>
                    <Button x:Name="StartGameButton"
                            Text="Começar partida"
                            Clicked="OnStartGameClicked"
                            IsEnabled="False"/>
                </HorizontalStackLayout>

                <CollectionView x:Name="LobbyPlayersCollection"
                                HeightRequest="220">
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Frame Margin="0,0,0,8"
                                   Padding="12"
                                   BackgroundColor="#F7F7F7"
                                   BorderColor="#DDDDDD">
                                <Label Text="{Binding .}"/>
                            </Frame>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </VerticalStackLayout>

            <VerticalStackLayout x:Name="RevealSection"
                                 IsVisible="False"
                                 Spacing="12">
                <Label Text="2) Revelação secreta"
                       FontAttributes="Bold"
                       FontSize="18"/>
                <Label x:Name="RevealPromptLabel"/>
                <Button x:Name="ShowRoleButton"
                        Text="Mostrar minha identidade"
                        Clicked="OnShowRoleClicked"/>

                <Frame x:Name="RoleCardFrame"
                       IsVisible="False"
                       Padding="16"
                       BackgroundColor="#FAFAFA"
                       BorderColor="#BBBBBB">
                    <VerticalStackLayout Spacing="8">
                        <Label Text="Seu papel"
                                FontAttributes="Bold"/>
                        <Label x:Name="RoleNameLabel"
                               FontSize="24"
                               FontAttributes="Bold"/>
                        <Label x:Name="RoleDescriptionLabel"/>
                    </VerticalStackLayout>
                </Frame>

                <Button x:Name="NextRevealButton"
                        IsVisible="False"
                        Text="Próximo jogador"
                        Clicked="OnNextRevealClicked"/>
            </VerticalStackLayout>

            <VerticalStackLayout x:Name="TeamSelectionSection"
                                 IsVisible="False"
                                 Spacing="12">
                <Label Text="3) Escolha da missão"
                       FontAttributes="Bold"
                       FontSize="18"/>
                <Label x:Name="LeaderLabel"/>
                <Label x:Name="RoundInfoLabel"/>
                <Label x:Name="SpecialRuleLabel"
                        TextColor="#B54708"/>
                <Label x:Name="TeamSelectionCountLabel"/>

                <CollectionView x:Name="TeamPlayersCollection"
                                SelectionMode="Multiple"
                                SelectionChanged="OnTeamSelectionChanged"
                                HeightRequest="280">
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Frame Margin="0,0,0,8"
                                   Padding="12"
                                   BackgroundColor="#F7F7F7"
                                   BorderColor="#DDDDDD">
                                <Label Text="{Binding Name}"/>
                            </Frame>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

                <Button x:Name="ConfirmTeamButton"
                        Text="Confirmar equipe da missão"
                        IsEnabled="False"
                        Clicked="OnConfirmTeamClicked"/>
            </VerticalStackLayout>

            <VerticalStackLayout x:Name="MissionVoteSection"
                                 IsVisible="False"
                                 Spacing="12">
                <Label Text="4) Votação secreta da missão"
                       FontAttributes="Bold"
                       FontSize="18"/>
                <Label x:Name="VotingPlayerLabel"/>
                <Label x:Name="VotingHintLabel"/>

                <Button x:Name="RevealVoteOptionsButton"
                        Text="Estou pronto para votar"
                        Clicked="OnRevealVoteOptionsClicked"/>

                <VerticalStackLayout x:Name="VoteButtonsPanel"
                                     IsVisible="False"
                                     Spacing="10">
                    <Button x:Name="CooperateButton"
                            Text="Cooperar"
                            BackgroundColor="#D1FADF"
                            Clicked="OnCooperateClicked"/>
                    <Button x:Name="SabotageButton"
                            Text="Sabotar"
                            BackgroundColor="#FECACA"
                            Clicked="OnSabotageClicked"/>
                </VerticalStackLayout>
            </VerticalStackLayout>

            <VerticalStackLayout x:Name="MissionResultSection"
                                 IsVisible="False"
                                 Spacing="12">
                <Label Text="5) Resultado da missão"
                       FontAttributes="Bold"
                       FontSize="18"/>
                <Label x:Name="MissionOutcomeLabel"
                       FontSize="24"
                       FontAttributes="Bold"/>
                <Label x:Name="MissionSummaryLabel"/>
                <Label x:Name="MissionRuleSummaryLabel"/>
                <Label x:Name="MissionHistoryLabel"/>
                <Button x:Name="ContinueAfterMissionButton"
                        Text="Próxima missão"
                        Clicked="OnContinueAfterMissionClicked"/>
            </VerticalStackLayout>

            <VerticalStackLayout x:Name="GameOverSection"
                                 IsVisible="False"
                                 Spacing="12">
                <Label Text="Fim de jogo"
                       FontAttributes="Bold"
                       FontSize="18"/>
                <Label x:Name="GameOverLabel"
                       FontSize="24"
                       FontAttributes="Bold"/>
                <Label x:Name="FinalHistoryLabel"/>
                <Button Text="Nova partida"
                        Clicked="OnRestartGameClicked"/>
            </VerticalStackLayout>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
